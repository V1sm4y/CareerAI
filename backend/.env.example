# CareerForge AI — Backend Environment Variables
# Copy this file to .env and fill in all values before running.

# ── REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# The app will REFUSE TO START if this is missing, too short, or is a known example value.
SECRET_KEY=REPLACE_WITH_OUTPUT_OF_ABOVE_COMMAND

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite:///./careerforge.db
UPLOAD_DIR=uploads
LOG_DIR=logs
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── AI Resume Analysis Backend ─────────────────────────────────────────────────
# Options: ollama (local) | groq (free cloud) | mistral (cloud) | heuristic (no AI)
ANALYZER_BACKEND=ollama

# Groq (free tier — https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768

# Mistral API (https://api.mistral.ai)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Ollama (local — https://ollama.ai)
OLLAMA_MODEL=mistral:latest
OLLAMA_BASE_URL=http://localhost:11434
